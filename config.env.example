# config.env — health-mcp (Google Health API v4, read-only).
#
# Copy to config.env and fill in the OAuth values. The two SECRET values
# (CLIENT_SECRET, REFRESH_TOKEN) are left blank here on purpose — the app fails
# fast at startup with a clear "X is required" error if they are missing, rather
# than 401-ing per call. NEVER commit real secret values.

# ── MCP listen address ──
HEALTH_MCP_HOST=0.0.0.0
HEALTH_MCP_PORT=9226
ASPNETCORE_URLS=http://0.0.0.0:9226

# ── OAuth2 (a Google Desktop OAuth client with access_type=offline) ──
# CLIENT_ID is not secret. CLIENT_SECRET + REFRESH_TOKEN are secret. See the README
# "Operator bootstrap" section for how to obtain the refresh token once.
GOOGLE_HEALTH_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REFRESH_TOKEN=

# ── Endpoints (defaults are the real Google endpoints; override only for testing) ──
GOOGLE_HEALTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
GOOGLE_HEALTH_API_BASE=https://health.googleapis.com/v4

# ── Advertised data types (weight/sleep/steps verified; heart_rate best-effort) ──
GOOGLE_HEALTH_DATA_TYPES=weight,sleep,steps,heart_rate

# ── Time-window query-param names for health_list_datapoints start/end ──
# UNVERIFIED against the live v4 API (the initial probe proved only the param-less
# list). Env-configurable so the running service can be tuned to the real names
# without a rebuild. Set either to empty to stop forwarding that bound entirely.
GOOGLE_HEALTH_START_PARAM=startTime
GOOGLE_HEALTH_END_PARAM=endTime
