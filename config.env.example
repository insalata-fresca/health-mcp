# config.env — health-mcp (Google Health API v4, read-only).
#
# Copy to config.env and fill in the OAuth values. The two SECRET values
# (CLIENT_SECRET, REFRESH_TOKEN) are left blank here on purpose — the app fails
# fast at startup with a clear "X is required" error if they are missing, rather
# than 401-ing per call. NEVER commit real secret values.

# ── MCP listen address ──
HEALTH_MCP_HOST=0.0.0.0
HEALTH_MCP_PORT=9226
ASPNETCORE_URLS=http://0.0.0.0:9226

# ── OAuth2 (a Google Desktop OAuth client with access_type=offline) ──
# CLIENT_ID is not secret. CLIENT_SECRET + REFRESH_TOKEN are secret. See the README
# "Operator bootstrap" section for how to obtain the refresh token once.
GOOGLE_HEALTH_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REFRESH_TOKEN=

# ── Endpoints (defaults are the real Google endpoints; override only for testing) ──
GOOGLE_HEALTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
GOOGLE_HEALTH_API_BASE=https://health.googleapis.com/v4

# ── Advertised data types (weight/sleep/steps verified; heart_rate best-effort) ──
# nutrition-log is included so health_list_datapoints(dataType="nutrition-log") can
# read back what log_nutrition writes.
GOOGLE_HEALTH_DATA_TYPES=weight,sleep,steps,heart_rate,nutrition-log

# ── Time-window query-param names for health_list_datapoints start/end ──
# UNVERIFIED against the live v4 API (the initial probe proved only the param-less
# list). Env-configurable so the running service can be tuned to the real names
# without a rebuild. Set either to empty to stop forwarding that bound entirely.
GOOGLE_HEALTH_START_PARAM=startTime
GOOGLE_HEALTH_END_PARAM=endTime

# ── Nutrition WRITE (log_nutrition) — the ONLY write tool ──
# The refresh token must be re-consented to include the write scope
#   https://www.googleapis.com/auth/googlehealth.nutrition.writeonly
# (the read tools/scopes are unaffected — see README "Nutrition writes").
#
# Every shape/enum below was VERIFIED against the Google Health API v4 discovery
# document (health.googleapis.com/$discovery/rest?version=v4, 2026-07-16). They are
# kept env-overridable so a first-live-write 400 is a config fix, not a rebuild.
# NOTE: no successful live write has been performed yet — the write path is
# schema-verified but not yet round-trip-confirmed.
GOOGLE_HEALTH_NUTRITION_WRITE_ENABLED=true
GOOGLE_HEALTH_NUTRITION_DATATYPE=nutrition-log
GOOGLE_HEALTH_NUTRITION_WRAPPER_KEY=nutritionLog
# EnergyQuantity carries the value under "kcal"; WeightQuantity under "grams" (raw numbers).
GOOGLE_HEALTH_ENERGY_VALUE_KEY=kcal
GOOGLE_HEALTH_MASS_VALUE_KEY=grams
# Optional userProvidedUnit enums (empty = omit; kcal/grams are already canonical).
# Verified enum members include KILOCALORIE (EnergyUnit) and GRAM (WeightUnit).
GOOGLE_HEALTH_ENERGY_UNIT=
GOOGLE_HEALTH_MASS_UNIT=
# Nutrient enum value for the protein entry (verified: PROTEIN).
GOOGLE_HEALTH_PROTEIN_NUTRIENT=PROTEIN
# tool meal arg -> Google Health MealType enum (verified: BREAKFAST/LUNCH/DINNER/SNACK).
GOOGLE_HEALTH_MEALTYPE_MAP=breakfast=BREAKFAST,lunch=LUNCH,dinner=DINNER,snack=SNACK
